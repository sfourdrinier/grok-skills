{
  "description": "SessionStart: Codex agent ensure + transfer stamp; SessionEnd stamp; optional stop-time Grok review gate; SubagentStop handoff nudge.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT}}/scripts/session-lifecycle-hook.mjs\" SessionStart",
            "timeout": 30,
            "statusMessage": "Grok session capture + Codex agents"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT}}/scripts/session-lifecycle-hook.mjs\" SessionEnd",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT}}/scripts/stop-review-gate-hook.mjs\"",
            "timeout": 900,
            "statusMessage": "Grok stop-review gate"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT}}/scripts/subagent-stop-hook.mjs\"",
            "timeout": 5,
            "statusMessage": "Grok handoff reminder"
          }
        ]
      }
    ]
  }
}
