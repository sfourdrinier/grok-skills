{
  "schemaVersion": 1,
  "title": "Protected write-deny globs (direct finalize + auto/peer apply pre-block)",
  "description": "Single-source deny-write glob list and golden match vectors for Python groklib.deny_write / direct_finalize.path_matches_deny and Node scripts/lib/deny-write.mjs. Match algorithm: POSIX-normalize by stripping a leading ./ prefix only (never strip a leading dotfile name), treat any path that has a path component named .git as denied (root, nested vendor/lib/.git, modules), then fnmatch each glob against the full normalized path OR the basename. Python uses stdlib fnmatch (where * matches /). Node mirrors that star-matches-slash semantics. Used by direct post-run deny scan/rollback and by the shared auto/peer apply spine pre-block (blocked-protected-path before git apply --check/apply). Do not copy this list into code.",
  "globs": [
    ".git",
    ".git/**",
    ".env",
    ".env.*",
    ".env/**",
    "*.pem",
    "*.key",
    "*.p12",
    "*.p8",
    ".git/hooks/**",
    ".githooks/**",
    "id_rsa",
    "id_dsa",
    "id_ecdsa",
    "id_ed25519",
    ".netrc",
    ".npmrc",
    ".envrc",
    "credentials.json"
  ],
  "matchVectors": [
